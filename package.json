    "@biomejs/biome": "^2.4.16",
    "@types/bun": "^1.3.14",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0"
  },
  "name": "bun-react-template",
  "overrides": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "private": true,
  "scripts": {
    "build": "bun run build.ts",
    "build:all": "bun run build.ts && bun run compile && bun run compile:worker",
    "compile": "bun build src/server/main.ts --outdir ./out/server --target bun",
    "compile:worker": "bun build src/server/worker.ts --outdir ./out/worker --target bun",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:pull": "drizzle-kit pull",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "dev": "bun --hot index-dev.ts",
    "format": "biome format .",
    "lint": "biome check .",
    "rbac:sync": "bun run src/modules/roles/domain/scripts/sync.ts",
    "start": "NODE_ENV=production bun index.ts",
    "worker": "WORKER_PORT=3001 bun run src/server/worker.ts"
  },
  "type": "module",
  "version": "0.1.0"
}
